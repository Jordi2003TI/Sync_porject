<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jorlina.syncapp"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="36" />

    <uses-permission android:name="android.permission.INTERNET" />

    <permission
        android:name="com.jorlina.syncapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.jorlina.syncapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.SyncApp" >
        <activity
            android:name="com.jorlina.syncapp.PerfilPatchActivity"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.model.PerfilHolder"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.SpalshActivity"
            android:exported="true"
            android:theme="@style/Theme.App.SplashScreen" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.jorlina.syncapp.PreferenciasActivity"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.AyudaActivity"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.preferencias"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.ayuda"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.CreateActivity"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.Perfil"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.Filtros"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.MenuPrincipalActivity"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.CreateAccount.CreateAcontActivity"
            android:exported="false" />
        <activity
            android:name="com.jorlina.syncapp.MainLogin.MainActivity"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.jorlina.syncapp.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>